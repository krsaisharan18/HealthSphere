# MongoDB connection string
# Replace with your actual MongoDB URI
# Local:  mongodb://localhost:27017/healthsphere
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/healthsphere
MONGODB_URI=mongodb://localhost:27017/healthsphere

# JWT secret - use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server port
PORT=5000

# Frontend URL for CORS (adjust if your frontend runs on a different port)
CLIENT_URL=http://localhost:3000

# Node environment
NODE_ENV=development
